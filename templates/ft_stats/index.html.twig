{% extends 'base.html.twig' %}

{% block title %}Statistiques France Travail{% endblock %}

{% block body %}
    <h1>Statistiques France Travail</h1>

    <div class="table-responsive">
        <table class="table table-bordered table-hover table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Toutes sources</th>
                    <th>France Travail uniquement</th>                  
                    <th>Toutes sources CDI</th>
                    <th>France Travail CDI</th>
                    <th>Toutes sources < 1 jour </th>
                     <th>France travail < 1 jour</th>
                </tr>
            </thead>
            <tbody>
            {% for s in ft_stats %}
                <tr>
                    <td class="text-center">{{ s.date ? s.date|date('d/m/Y') : '' }}</td>
                    <td class="text-end">{{ s.jobs }}</td>
                    <td class="text-end">{{ s.jobsFt }}</td>
                    <td class="text-end">{{ s.jobsCdi }}</td>
                    <td class="text-end">{{ s.jobsFtCdi }}</td>
                    <td class="text-end">{{ s.jobs1j }}</td>
                    <td class="text-end">{{ s.jobsFt1j }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7"><span class="alert alert-danger">Aucune donnée.</span></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
